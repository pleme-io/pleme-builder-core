{
  "name": "@pleme/builder-core",
  "version": "0.1.0",
  "description": "Universal builder infrastructure for drag-drop composition UIs (sequences, task lists, etc.)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@xstate/react": "^4.1.0",
    "immer": "^10.1.1",
    "xstate": "^5.18.0",
    "zustand": "^5.0.2"
  },
  "peerDependencies": {
    "@apollo/client": "^3.11.0",
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.0.0",
    "graphql": "^16.9.0",
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.0",
    "jsdom": "^27.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  },
  "keywords": [
    "builder",
    "drag-drop",
    "sequence",
    "task-list",
    "optimistic-ui",
    "zustand",
    "dnd-kit"
  ],
  "author": "Pleme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pleme-io/pleme-builder-core.git"
  }
}
